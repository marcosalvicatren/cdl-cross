# File: .streamlit/secrets.toml
# Copiare questo file in .streamlit/secrets.toml e compilare i valori.
# Su Streamlit Cloud: incollare il contenuto in App Settings → Secrets.

# Token GitHub con permesso "repo" (lettura + scrittura)
# Generare su: https://github.com/settings/tokens → Fine-grained tokens
# Permessi necessari: Contents → Read and Write
GITHUB_TOKEN = "ghp_xxxxxxxxxxxxxxxxxxxx"

# Nome del repository nel formato "utente/nome-repo"
GITHUB_REPO = "tuo-utente/prima-nota-paghe"

# Branch su cui salvare le regole (di solito "main")
GITHUB_BRANCH = "main"
